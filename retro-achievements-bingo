<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Random RetroAchievement</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 40px;
	  background: black;
	  color: white;
    }
	.green {
	  background-color: green;
	}
	.yellow {
	  background-color: yellow;	
	}
	.red {
	  background-color: red;
	}
    img {
      max-width: 100px;
    }
    button {
      padding: 10px 20px;
      font-size: 16px;
      cursor: pointer;
    }
    
    td {
      width: 112px;
      height: 112px;
      border: solid white 2px;
    }
  </style>
</head>
<body>

  RetroAchievements Username: <input id="username"></input><br>
  API Key: <input id="api"></input><br><br>
  <span id="gamesNum"></span><br>
  <button onclick="getWantToPlay()">Create Bingo Board</button><br><br>
  <button class="green" onclick="changeColor('green')">Green</button>
  <button class="yellow" onclick="changeColor('yellow')">Yellow</button>
  <button class="red" onclick="changeColor('red')">Red</button>
  <button onclick="changeColor('reroll')">reroll</button><br><br>
 
  <div id="bingo">
    <table style="margin: 0px auto;">
    <td id="0-0" onClick="clicked(0,0)"></td><td id="0-1" onClick="clicked(0,1)"></td><td id="0-2" onClick="clicked(0,2)"></td><td id="0-3" onClick="clicked(0,3)"></td><td id="0-4" onClick="clicked(0,4)"></td> <tr>
    <td id="1-0" onClick="clicked(1,0)"></td><td id="1-1" onClick="clicked(1,1)"></td><td id="1-2" onClick="clicked(1,2)"></td><td id="1-3" onClick="clicked(1,3)"></td><td id="1-4" onClick="clicked(1,4)"></td> <tr>
	<td id="2-0" onClick="clicked(2,0)"></td><td id="2-1" onClick="clicked(2,1)"></td><td id="2-2" onClick="clicked(2,2)"></td><td id="2-3" onClick="clicked(2,3)"></td><td id="2-4" onClick="clicked(2,4)"></td> <tr>
	<td id="3-0" onClick="clicked(3,0)"></td><td id="3-1" onClick="clicked(3,1)"></td><td id="3-2" onClick="clicked(3,2)"></td><td id="3-3" onClick="clicked(3,3)"></td><td id="3-4" onClick="clicked(3,4)"></td> <tr>
	<td id="4-0" onClick="clicked(4,0)"></td><td id="4-1" onClick="clicked(4,1)"></td><td id="4-2" onClick="clicked(4,2)"></td><td id="4-3" onClick="clicked(4,3)"></td><td id="4-4" onClick="clicked(4,4)"></td>
    </table>
  </div><br><br><br><br>
  
  <div id="results"></div>

  <script>
	const gameIDs = [];
	var tempGameIDs = [...gameIDs];
	var USERNAME = "";
    var API_KEY = "";
	
	document.getElementById("gamesNum").innerHTML = gameIDs.length + " games loaded";
    
    var rand1 = Math.floor(Math.random() * (gameIDs.length - 0 + 1));
    var GAME_ID = gameIDs[rand1]; 

    var i = 0;
	var j = 0;
	var k = 0;

    var highlight = "yellow";

	function clicked(row, column) {
		if (highlight == "reroll") {
			getRandomAchievement(row, column);
		} else { 
			document.getElementById(row + "-" + column).style.backgroundColor = highlight;
		}
	}

    function changeColor(color) {
	  highlight = color;
	}
	
	async function getWantToPlay() {
		USERNAME = document.getElementById("username").value;
		var username1 = document.getElementById("username").value;
		API_KEY = document.getElementById("api").value;
		var webApiKey = document.getElementById("api").value;
		try {	
			const apiUrl1 = "https://retroachievements.org/API/API_GetUserWantToPlayList.php?y=" + webApiKey + "&u=" + username1 + "&c=100&o=0";
			const url1 = apiUrl1;
			const res1 = await fetch(url1);
			const data1 = await res1.json();
			for (i = 0; i < data1.Results.length; i++) {
				gameIDs.push(data1.Results[i].ID);
			}
			document.getElementById("gamesNum").innerHTML = gameIDs.length + " games loaded";
			getRandomAchievement();
		} catch (err) {
			await delay(250); 
		}
	}

	var randomized = false;

	var bingoSize = 5;
    async function getRandomAchievement(a, b) {
		if (a === undefined) {
		  if (!randomized) {
			for (i = 0; i < bingoSize; i++) {
				for (j = 0; j < bingoSize; j++) {
					if (tempGameIDs.length < 1) {
						tempGameIDs = [...gameIDs];
					}
					rand1 = Math.floor(Math.random() * (tempGameIDs.length - 0));
					GAME_ID = tempGameIDs[rand1]; 
					tempGameIDs.splice(rand1, 1);
					try {	
						const apiUrl = `https://retroachievements.org/API/API_GetGameExtended.php?z=${USERNAME}&y=${API_KEY}&i=${GAME_ID}`;
						const url = apiUrl;
						const res = await fetch(url);
						const data = await res.json();
						const achievements = data.Achievements || [];
						if (!achievements.length) {	
							const achievementsObj = data.Achievements || {};
							const max = (data.NumAchievements);
							const rand = Math.floor(Math.random() * (max - 0));
							const keys = Object.keys(achievementsObj);
							const firstKey = keys[rand];
							const firstAchievement = achievementsObj[firstKey];
							document.getElementById(i + "-" + j).innerHTML = "<img src='https://media.retroachievements.org" + data.ImageIcon + "'>"
							document.getElementById(i + "-" + j).title = data.Title + " \u000A " + firstAchievement.Title + " \n " + firstAchievement.Description;
							document.getElementById("results").innerHTML += GAME_ID + " | " + data.Title + " | " + firstAchievement.Title + " | " + firstAchievement.Description + "<br>";
							if (j == 4) {	
								document.getElementById("results").innerHTML += "<br>";
							}
						}
						const randomAch = achievements[Math.floor(Math.random() * achievements.length)];
					} catch (err) {
					    await delay(250); 
					}
				}
			}
			randomized = true;
		  }
		} else {
			tempGameIDs = [...gameIDs];
			rand1 = Math.floor(Math.random() * (tempGameIDs.length - 0 + 1));
			GAME_ID = tempGameIDs[rand1];
			tempGameIDs.splice(rand1, 1);
			try {	
				const apiUrl = `https://retroachievements.org/API/API_GetGameExtended.php?z=${USERNAME}&y=${API_KEY}&i=${GAME_ID}`;
				const url = apiUrl;
				const res = await fetch(url);
				const data = await res.json();
				const achievements = data.Achievements || [];
				if (!achievements.length) {	
					const achievementsObj = data.Achievements || {};
					const max = (data.NumAchievements);
					const rand = Math.floor(Math.random() * (max - 0 + 1));
					const keys = Object.keys(achievementsObj);
					const firstKey = keys[rand];
					const firstAchievement = achievementsObj[firstKey];
					document.getElementById(a + "-" + b).innerHTML = "<img src='https://media.retroachievements.org" + data.ImageIcon + "'>"
					document.getElementById(a + "-" + b).title = data.Title + " | " + firstAchievement.Title + " | " + firstAchievement.Description;
					document.getElementById("results").innerHTML += GAME_ID + " | " + data.Title + " | " + firstAchievement.Title + " | " + firstAchievement.Description + "<br>";
					if (j == 4) {	
						document.getElementById("results").innerHTML += "<br>";
					}
				}
				const randomAch = achievements[Math.floor(Math.random() * achievements.length)];
			} catch (err) {
				document.getElementById("results").innerHTML += " [ " + GAME_ID + " ] ";
				console.error("ERROR:", err);
			}
		}
	}
	
	function delay(ms) {
		return new Promise(resolve => setTimeout(resolve, ms));
	}
  </script>

</body>
</html>
